generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  TECHNICIAN
}

enum SkillLevel {
  JUNIOR
  MID
  SENIOR
  EXPERT
}

enum Shift {
  MORNING
  AFTERNOON
  NIGHT
}

enum WarehouseType {
  MAIN
  SUB
  OUTDOOR
}

enum TransactionType {
  IN
  OUT
  TRANSFER
  ADJUST
  RETURN
}

enum ToolStatus {
  AVAILABLE
  BORROWED
  MAINTENANCE
  BROKEN
}

enum ToolCondition {
  GOOD
  FAIR
  POOR
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

enum MaterialIssueStatus {
  DRAFT
  APPROVED
  ISSUED
  CANCELLED
}

enum StockCountStatus {
  DRAFT
  COUNTING
  COMPLETED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  employeeCode String   @unique @map("employee_code")
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  phone        String?
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  departmentId String?     @db.Uuid @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  technician Technician?

  purchaseOrders    PurchaseOrder[]    @relation("POCreator")
  goodsReceipts     GoodsReceipt[]     @relation("GRReceiver")
  issueRequests     MaterialIssue[]    @relation("IssueRequester")
  issueApprovals    MaterialIssue[]    @relation("IssueApprover")
  stockCounts       StockCount[]       @relation("StockCounter")
  stockTransactions StockTransaction[] @relation("TxUser")

  borrowedTools ToolBorrowRecord[] @relation("ToolBorrower")
  returnedTools ToolBorrowRecord[] @relation("ToolReturner")
  auditLogs     AuditLog[]

  @@map("users")
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("departments")
}

model Technician {
  id         String     @id @db.Uuid
  skillLevel SkillLevel @default(JUNIOR) @map("skill_level")
  shift      Shift      @default(MORNING)
  specialty  String?

  user User @relation(fields: [id], references: [id])

  @@map("technicians")
}

model MaterialCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  materials Material[]

  @@map("material_categories")
}

model Material {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  description String?
  unit        String
  minStock    Decimal? @db.Decimal(10, 2) @map("min_stock")

  categoryId String           @db.Uuid @map("category_id")
  category   MaterialCategory @relation(fields: [categoryId], references: [id])

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stocks             Stock[]
  stockTransactions  StockTransaction[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiptItems  GoodsReceiptItem[]
  materialIssueItems MaterialIssueItem[]
  stockCountItems    StockCountItem[]

  @@map("materials")
}

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchaseOrders PurchaseOrder[]
  goodsReceipts  GoodsReceipt[]

  @@map("suppliers")
}

model Warehouse {
  id        String        @id @default(uuid()) @db.Uuid
  code      String        @unique
  name      String
  type      WarehouseType @default(MAIN)
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  locations   WarehouseLocation[]
  stockCounts StockCount[]

  @@map("warehouses")
}

model WarehouseLocation {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  description String?
  warehouseId String    @db.Uuid @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  isActive    Boolean   @default(true) @map("is_active")

  stocks             Stock[]
  goodsReceiptItems  GoodsReceiptItem[]
  materialIssueItems MaterialIssueItem[]
  stockCountItems    StockCountItem[]
  stockTransactions  StockTransaction[]
  tools              Tool[]

  @@map("warehouse_locations")
}

model Stock {
  id         String   @id @default(uuid()) @db.Uuid
  materialId String   @db.Uuid @map("material_id")
  locationId String   @db.Uuid @map("location_id")
  quantity   Decimal  @db.Decimal(10, 2)
  updatedAt  DateTime @updatedAt @map("updated_at")

  material Material          @relation(fields: [materialId], references: [id])
  location WarehouseLocation @relation(fields: [locationId], references: [id])

  @@unique([materialId, locationId])
  @@map("stock")
}

model StockTransaction {
  id          String          @id @default(uuid()) @db.Uuid
  materialId  String          @db.Uuid @map("material_id")
  locationId  String?         @db.Uuid @map("location_id")
  type        TransactionType
  quantity    Decimal         @db.Decimal(10, 2)
  referenceId String?         @map("reference_id")
  note        String?
  createdAt   DateTime        @default(now()) @map("created_at")
  createdBy   String?         @db.Uuid @map("created_by")

  creator  User?              @relation("TxUser", fields: [createdBy], references: [id])
  material Material           @relation(fields: [materialId], references: [id])
  location WarehouseLocation? @relation(fields: [locationId], references: [id])

  @@map("stock_transactions")
}

model PurchaseOrder {
  id         String              @id @default(uuid()) @db.Uuid
  poNumber   String              @unique @map("po_number")
  supplierId String              @db.Uuid @map("supplier_id")
  status     PurchaseOrderStatus @default(DRAFT)
  note       String?
  createdBy  String              @db.Uuid @map("created_by")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  approvedBy String?             @db.Uuid @map("approved_by")
  approvedAt DateTime?           @map("approved_at")

  supplier Supplier @relation(fields: [supplierId], references: [id])
  creator  User     @relation("POCreator", fields: [createdBy], references: [id])

  items         PurchaseOrderItem[]
  goodsReceipts GoodsReceipt[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  purchaseOrderId String  @db.Uuid @map("purchase_order_id")
  materialId      String  @db.Uuid @map("material_id")
  quantity        Decimal @db.Decimal(10, 2)
  unitPrice       Decimal @db.Decimal(10, 2) @map("unit_price")
  receivedQty     Decimal @default(0) @db.Decimal(10, 2) @map("received_qty")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  material      Material      @relation(fields: [materialId], references: [id])

  @@unique([purchaseOrderId, materialId])
  @@map("purchase_order_items")
}

model GoodsReceipt {
  id         String   @id @default(uuid()) @db.Uuid
  receiptNo  String   @unique @map("receipt_no")
  supplierId String   @db.Uuid @map("supplier_id")
  poId       String?  @db.Uuid @map("po_id")
  receivedBy String   @db.Uuid @map("received_by")
  note       String?
  receivedAt DateTime @default(now()) @map("received_at")

  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  receiver      User           @relation("GRReceiver", fields: [receivedBy], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [poId], references: [id])
  items         GoodsReceiptItem[]

  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id         String  @id @default(uuid()) @db.Uuid
  receiptId  String  @db.Uuid @map("receipt_id")
  materialId String  @db.Uuid @map("material_id")
  locationId String  @db.Uuid @map("location_id")
  quantity   Decimal @db.Decimal(10, 2)
  unitPrice  Decimal @default(0) @db.Decimal(10, 2) @map("unit_price")

  receipt  GoodsReceipt      @relation(fields: [receiptId], references: [id])
  material Material          @relation(fields: [materialId], references: [id])
  location WarehouseLocation @relation(fields: [locationId], references: [id])

  @@map("goods_receipt_items")
}

model MaterialIssue {
  id          String              @id @default(uuid()) @db.Uuid
  issueNo     String              @unique @map("issue_no")
  requestedBy String              @db.Uuid @map("requested_by")
  approvedBy  String?             @db.Uuid @map("approved_by")
  purpose     String?
  status      MaterialIssueStatus @default(DRAFT)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  requester User  @relation("IssueRequester", fields: [requestedBy], references: [id])
  approver  User? @relation("IssueApprover", fields: [approvedBy], references: [id])
  items     MaterialIssueItem[]

  @@map("material_issues")
}

model MaterialIssueItem {
  id         String  @id @default(uuid()) @db.Uuid
  issueId    String  @db.Uuid @map("issue_id")
  materialId String  @db.Uuid @map("material_id")
  locationId String  @db.Uuid @map("location_id")
  quantity   Decimal @db.Decimal(10, 2)

  issue    MaterialIssue     @relation(fields: [issueId], references: [id])
  material Material          @relation(fields: [materialId], references: [id])
  location WarehouseLocation @relation(fields: [locationId], references: [id])

  @@unique([issueId, materialId, locationId])
  @@map("material_issue_items")
}

model StockCount {
  id          String           @id @default(uuid()) @db.Uuid
  countNo     String           @unique @map("count_no")
  warehouseId String           @db.Uuid @map("warehouse_id")
  countedBy   String           @db.Uuid @map("counted_by")
  note        String?
  status      StockCountStatus @default(DRAFT)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  completedAt DateTime?        @map("completed_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  counter   User      @relation("StockCounter", fields: [countedBy], references: [id])
  items     StockCountItem[]

  @@map("stock_counts")
}

model StockCountItem {
  id           String  @id @default(uuid()) @db.Uuid
  stockCountId String  @db.Uuid @map("stock_count_id")
  materialId   String  @db.Uuid @map("material_id")
  locationId   String  @db.Uuid @map("location_id")
  systemQty    Decimal @db.Decimal(10, 2) @map("system_qty")
  countedQty   Decimal @db.Decimal(10, 2) @map("counted_qty")
  note         String?

  stockCount StockCount        @relation(fields: [stockCountId], references: [id])
  material   Material          @relation(fields: [materialId], references: [id])
  location   WarehouseLocation @relation(fields: [locationId], references: [id])

  @@unique([stockCountId, materialId, locationId])
  @@map("stock_count_items")
}

model ToolCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tools Tool[]

  @@map("tool_categories")
}

model Tool {
  id           String             @id @default(uuid()) @db.Uuid
  code         String             @unique
  name         String
  description  String?
  serialNumber String?            @unique @map("serial_number")
  status       ToolStatus         @default(AVAILABLE)
  condition    ToolCondition      @default(GOOD)
  categoryId   String             @db.Uuid @map("category_id")
  category     ToolCategory       @relation(fields: [categoryId], references: [id])
  locationId   String?            @db.Uuid @map("location_id")
  location     WarehouseLocation? @relation(fields: [locationId], references: [id])
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  borrowRecords ToolBorrowRecord[]

  @@map("tools")
}

model ToolBorrowRecord {
  id                String         @id @default(uuid()) @db.Uuid
  toolId            String         @db.Uuid @map("tool_id")
  borrowedBy        String         @db.Uuid @map("borrowed_by")
  returnedBy        String?        @db.Uuid @map("returned_by")
  borrowedAt        DateTime       @default(now()) @map("borrowed_at")
  dueAt             DateTime?      @map("due_at")
  returnedAt        DateTime?      @map("returned_at")
  purpose           String?
  conditionOnBorrow ToolCondition  @default(GOOD) @map("condition_on_borrow")
  conditionOnReturn ToolCondition? @map("condition_on_return")
  note              String?

  tool     Tool  @relation(fields: [toolId], references: [id])
  borrower User  @relation("ToolBorrower", fields: [borrowedBy], references: [id])
  returner User? @relation("ToolReturner", fields: [returnedBy], references: [id])

  @@map("tool_borrow_records")
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  CANCEL
  ISSUE
  BORROW
  RETURN
  ADJUST
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @db.Uuid @map("user_id")
  action     AuditAction
  entity     String      // ชื่อ model เช่น "Stock", "MaterialIssue"
  entityId   String      @map("entity_id")
  oldValues  Json?       @map("old_values")   // ค่าก่อนเปลี่ยน
  newValues  Json?       @map("new_values")   // ค่าหลังเปลี่ยน
  diff       Json?                             // เฉพาะ field ที่เปลี่ยน
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  note       String?
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
